NODE_ENV=production
TZ=Europe/Warsaw

# PostgreSQL (external shared server)
# Docker: host.docker.internal | native dev: localhost
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=evpanel
POSTGRES_PASSWORD=change_me
POSTGRES_DB=evpanel
DB_SYNC=false

# Backend
BACKEND_PORT=3000
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=30d
CORS_ORIGIN=https://your-domain.example

# Internal service URLs
SCRAPER_INTERNAL_URL=http://evpanel-scraper:3100
INTERNAL_API_TOKEN=change_me_internal_token

# AI provider
AI_PROVIDER=noop
AI_API_KEY=
