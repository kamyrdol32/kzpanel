# ──────────────────────────────────────────────────────────────
# EvPanel 2.0 — DOCKER / PRODUCTION environment template.
# Copy to .env.docker and set real secrets, then:
#   docker compose --env-file .env.docker up -d --build
# Hosts use compose service names (db, backend, scraper) on the internal network.
# ──────────────────────────────────────────────────────────────

# --- Shared / global ---
NODE_ENV=production
TZ=Europe/Warsaw

# --- PostgreSQL (compose service name) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=evpanel
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=evpanel
# Migrations are the single source of truth; they run automatically on backend start.
DB_SYNC=false

# --- Backend (NestJS API) ---
BACKEND_PORT=3000
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=30d
CORS_ORIGIN=https://your-domain.example

# --- Scraper (NestJS worker) ---
SCRAPER_PORT=3100
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_CRON=0 0 4 * * *
SCRAPER_LIMIT=20
SCRAPER_MOCK=false

# --- Internal service-to-service URLs (compose service names) ---
SCRAPER_INTERNAL_URL=http://scraper:3100
BACKEND_INTERNAL_URL=http://backend:3000
INTERNAL_API_TOKEN=change_me_internal_token

# --- AI provider (na razie no-op) ---
AI_PROVIDER=noop          # noop | claude | openai (faza późniejsza)
AI_API_KEY=

# --- Frontend (build-time) ---
FRONTEND_API_URL=/api
