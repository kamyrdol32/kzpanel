# ──────────────────────────────────────────────────────────────
# EvPanel 2.0 — LOCAL DEV environment template (apps run natively, no Docker).
# Copy to .env and adjust. For Docker/prod see .env.docker.example.
# ──────────────────────────────────────────────────────────────

# --- Shared / global ---
NODE_ENV=development
TZ=Europe/Warsaw

# --- PostgreSQL (localhost — native dev) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=evpanel
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=evpanel
# Schema is owned by migrations (single source of truth). Keep false — run `npm run migration:run`.
DB_SYNC=false

# --- Backend (NestJS API) ---
BACKEND_PORT=3000
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=30d
CORS_ORIGIN=http://localhost:4200

# --- Scraper (NestJS worker) ---
SCRAPER_PORT=3100
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_CRON=0 0 4 * * *
SCRAPER_LIMIT=20
SCRAPER_MOCK=false

# --- Internal service-to-service URLs (native = localhost) ---
SCRAPER_INTERNAL_URL=http://localhost:3100
BACKEND_INTERNAL_URL=http://localhost:3000
INTERNAL_API_TOKEN=change_me_internal_token

# --- AI provider (na razie no-op) ---
AI_PROVIDER=noop          # noop | claude | openai (faza późniejsza)
AI_API_KEY=

# --- Frontend (build-time) ---
FRONTEND_API_URL=/api
